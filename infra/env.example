# Copy to .env at repo root. Never commit .env.

BRAND=Suppr
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
BOT_URL=http://localhost:3002   # production: https://bot.suppr.co — used for Twilio signature validation
SERVICE_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_STORAGE_BUCKET_IMAGES=suppr-media
SUPABASE_STORAGE_BUCKET_VIDEO=suppr-video

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Fast conversational (concierge bot, autofill, comms) → Azure AI Foundry · Llama 4 Maverick
AZURE_ENDPOINT=https://<resource>.services.ai.azure.com
AZURE_API_KEY=
BOT_MODEL=Llama-4-Maverick-17B-128E-Instruct-FP8

# High-stakes reasoning (refund calc, reconciliation) → Nebius token factory · DeepSeek V3.2
NEBIUS_API_KEY=
NEBIUS_API_URL=https://api.tokenfactory.nebius.com/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3.2

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=          # Destination 1 — your account (stripe webhook_endpoints create)
STRIPE_WEBHOOK_SECRET_CONNECT=  # Destination 2 — connected accounts (stripe webhook_endpoints create --connect)
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=                 # +1... E.164 — SMS inbound → bot.suppr.co/webhooks/twilio/sms
TWILIO_WHATSAPP_FROM=            # whatsapp:+1... — set once WhatsApp number is approved

# iMessage — Blooio (https://blooio.com)
BLOOIO_API_KEY=
BLOOIO_BASE_URL=https://backend.blooio.com/v2/api
BLOOIO_WEBHOOK_SECRET=  # whsec_<hex> — returned by POST /webhooks registration
BLOOIO_WEBHOOK_ID=      # wh_<id>   — returned by POST /webhooks registration

# Resend
RESEND_API_KEY=
RESEND_FROM=hello@suppr.co
RESEND_DOMAIN_ID=   # returned by POST /domains — use to check verification status

# Mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=   # from Mux Dashboard → Settings → Webhooks → signing secret

# Azure
AZURE_CDN_ENDPOINT=
AZURE_CDN_HOSTNAME=
AZURE_STORAGE_CONNECTION_STRING=

# Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_BULK_LOYALTY_URL=
MODAL_APP_BULK_AUTOFILL_URL=

# Web Push
WEB_PUSH_VAPID_PUBLIC=
WEB_PUSH_VAPID_PRIVATE=
WEB_PUSH_CONTACT=mailto:team@suppr.co

# Render
RENDER_API_KEY=
